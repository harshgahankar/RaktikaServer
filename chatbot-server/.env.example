PORT=4000

# GROQ API key — get at https://console.groq.com
GROQ_API_KEY=

# Qdrant — local or cloud
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=

# Embedding model (ONNX, runs locally via fastembed)
# Small: BAAI/bge-small-en-v1.5 (~100MB) — recommended for Render free tier
# Base:  BAAI/bge-base-en-v1.5  (~400MB)
# Large: BAAI/bge-large-en-v1.5 (~1.3GB) — may exceed Render disk quota
EMBEDDING_MODEL=BAAI/bge-small-en-v1.5

# CORS — comma-separated origins
ALLOWED_ORIGINS=*
